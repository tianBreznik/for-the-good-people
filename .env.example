# Firebase Admin — local: save JSON as firebase-service-account.json
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
# Railway: use FIREBASE_SERVICE_ACCOUNT_JSON (minified one-line JSON, see RAILWAY.md)

# Firestore: authorAllowlist (approved emails), authorApplications (pending requests)

# --- Email when someone submits an author application ---
ADMIN_NOTIFY_EMAIL=you@example.com
# Optional extra recipients (comma-separated, or use ADMIN_NOTIFY_EMAIL=a@x.com,b@y.com)
ADMIN_NOTIFY_EMAIL_EXTRA=

# SMTP (Gmail: use an App Password, not your normal password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-app-password-here

# Optional
MAIL_FROM="Good People Posting <your-gmail@gmail.com>"
SITE_NAME=Good People Posting
